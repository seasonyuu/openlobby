{
  "name": "openlobby",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:parallel": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "build:cli": "pnpm --filter openlobby build",
    "prepublish:cli": "pnpm build:cli",
    "publish:cli": "pnpm build:cli && cd packages/cli && npm publish"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "@homebridge/node-pty-prebuilt-multiarch"]
  }
}
