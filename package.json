{
  "name": "cclobby",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "build:cli": "pnpm --filter cclobby build",
    "prepublish:cli": "pnpm build:cli",
    "publish:cli": "pnpm build:cli && cd packages/cli && npm publish"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild"]
  }
}
